{
  "id": "js-xiaohongshu-ops-skill",
  "name": "JS Xiaohongshu Ops Skill",
  "description": "小红书笔记详情与评论读取工具",
  "version": "1.0.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "jsEyesServerUrl": {
        "type": "string",
        "default": "ws://localhost:18080",
        "description": "JS-Eyes WebSocket 服务器地址"
      },
      "defaultMaxCommentPages": {
        "type": "number",
        "default": 0,
        "description": "默认评论翻页数"
      }
    }
  }
}
