{
  "name": "js-eyes-monorepo",
  "version": "2.9.0",
  "private": true,
  "description": "JS Eyes monorepo for npm CLI, runtime packages, and extension skills",
  "workspaces": [
    "apps/*",
    "packages/*",
    "skills/*"
  ],
  "scripts": {
    "dev": "npx serve src",
    "build": "node packages/devtools/bin/js-eyes-dev.js build all --clean --no-sign",
    "build:skill": "node packages/devtools/bin/js-eyes-dev.js build skill",
    "build:site": "node packages/devtools/bin/js-eyes-dev.js build site --clean",
    "build:chrome": "node packages/devtools/bin/js-eyes-dev.js build chrome",
    "build:firefox": "node packages/devtools/bin/js-eyes-dev.js build firefox",
    "build:firefox:dev": "node packages/devtools/bin/js-eyes-dev.js build firefox --no-sign",
    "preview": "npx serve dist -l 3000",
    "cli": "node apps/cli/bin/js-eyes.js",
    "devtools": "node packages/devtools/bin/js-eyes-dev.js",
    "bump": "node packages/devtools/bin/js-eyes-dev.js bump",
    "commit": "node packages/devtools/bin/js-eyes-dev.js commit",
    "sync": "node packages/devtools/bin/js-eyes-dev.js sync",
    "bundle": "node packages/devtools/bin/js-eyes-dev.js bundle",
    "publish:npm": "node packages/devtools/bin/js-eyes-dev.js release --skip-extensions --skip-tag --skip-github --skip-clawhub",
    "publish:workspaces": "node packages/devtools/bin/js-eyes-dev.js publish workspaces",
    "publish:workspaces:dry-run": "node packages/devtools/bin/js-eyes-dev.js publish workspaces --dry-run",
    "publish:clawhub": "node packages/devtools/bin/js-eyes-dev.js release --skip-bundle --skip-extensions --skip-npm --skip-tag --skip-github",
    "release": "node packages/devtools/bin/js-eyes-dev.js release",
    "release:dry-run": "node packages/devtools/bin/js-eyes-dev.js release --dry-run",
    "release:verify": "node scripts/verify-release.js",
    "release:prepare-packages": "node scripts/prepare-release-packages.js dist/release-packages",
    "release:publish-packages": "node scripts/publish-release-packages.js",
    "setup:gh-pages": "node packages/devtools/bin/js-eyes-dev.js setup-github-pages",
    "setup:cloudflare": "node packages/devtools/bin/js-eyes-dev.js setup-cloudflare",
    "test": "npm run test:all",
    "test:all": "npm run test:root && npm run test:workspaces",
    "test:root": "node --test test/*.test.js",
    "test:workspaces": "npm run test --workspaces --if-present",
    "test:coverage": "node scripts/test-coverage.js",
    "lint": "eslint apps packages skills extensions openclaw-plugin test scripts src",
    "lint:fix": "npm run lint -- --fix",
    "typecheck": "npm run typecheck:core && npm run typecheck:apps && npm run typecheck:plugin && npm run typecheck:devtools",
    "typecheck:core": "tsc -p jsconfig.core.json",
    "typecheck:apps": "tsc -p jsconfig.apps.json",
    "typecheck:plugin": "tsc -p jsconfig.plugin.json",
    "typecheck:devtools": "tsc -p jsconfig.devtools.json",
    "package:smoke": "node scripts/package-smoke.js",
    "scan:security": "node scripts/scan-clawhub-patterns.js",
    "skills:manifests": "node scripts/generate-skill-manifests.js",
    "skills:manifests:check": "node scripts/generate-skill-manifests.js --check",
    "sync:extension-shared": "node scripts/sync-extension-shared.js --write",
    "check:extension-shared": "node scripts/sync-extension-shared.js",
    "test:server": "node --test packages/server-core/tests/ws-handler.test.js packages/server-core/tests/security-hot-reload.test.js",
    "test:extension": "node --test test/utils.test.js test/extension-shared-runtime.test.js",
    "test:client": "node --test packages/client-sdk/tests/client.test.js",
    "test:cli": "node --test test/npm-cli.test.js",
    "test:native-host": "node --test apps/native-host/tests/*.test.js test/openclaw-native-host-setup.test.js",
    "server": "node apps/cli/bin/js-eyes.js server start --foreground"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "overrides": {
    "@modelcontextprotocol/sdk": {
      "@hono/node-server": "2.0.11"
    },
    "brace-expansion@<1.1.16": "1.1.16",
    "brace-expansion@>=2.0.0 <2.1.2": "2.1.2",
    "fast-uri": "4.1.1",
    "shell-quote": "1.10.0",
    "firefox-profile": {
      "adm-zip": "0.6.0"
    }
  },
  "dependencies": {
    "@js-eyes/visual-bridge-kit": "workspace:*",
    "archiver": "^7.0.1",
    "chokidar": "^3.6.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@modelcontextprotocol/sdk": "1.29.0",
    "@types/node": "^22.20.1",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.5",
    "globals": "^17.7.0",
    "typescript": "^7.0.2",
    "web-ext": "^10.5.0"
  }
}
