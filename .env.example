# Firefox AMO API 配置
# 获取 API 密钥: https://addons.mozilla.org/developers/addon/api/key/
AMO_API_KEY=your-jwt-issuer-here
AMO_API_SECRET=your-jwt-secret-here

# X API v2 配置（https://console.x.com）
# 只读请求优先使用 Bearer Token；发帖、回复、Quote、媒体上传需要 OAuth 1.0a 用户上下文四元组。
X_BEARER_TOKEN=your-x-api-bearer-token-here
X_API_KEY=your-x-api-key-here
X_API_SECRET=your-x-api-key-secret-here
X_ACCESS_TOKEN=your-x-access-token-here
X_ACCESS_TOKEN_SECRET=your-x-access-token-secret-here
